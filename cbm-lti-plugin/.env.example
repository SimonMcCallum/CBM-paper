# CBM LTI Plugin Configuration

# Server
PORT=3000
NODE_ENV=development

# Database (SQLite path)
DATABASE_PATH=./data/cbm-lti.db

# LTI 1.3
LTI_KEY=your-lti-secret-key
MONGODB_URI=mongodb://localhost:27017/cbm-lti
EXTERNAL_URL=http://localhost:3000

# Python sidecar (novelty_detector)
SIDECAR_URL=http://localhost:5000

# API Keys for question generation (System 2)
# Set these in the novelty_detector/.env file
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
